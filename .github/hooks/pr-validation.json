{
  "version": 1,
  "hooks": {
    "preToolUse": [
      {
        "type": "command",
        "bash": "./scripts/pr-validation.sh",
        "powershell": "bash ./scripts/pr-validation.sh",
        "cwd": ".",
        "timeoutSec": 1200,
        "env": {
          "DOTNET_CLI_TELEMETRY_OPTOUT": "1",
          "DOTNET_NOLOGO": "1"
        }
      }
    ]
  }
}
